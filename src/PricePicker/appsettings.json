{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft": "Warning"
    }
  },
  "Service": {
    "IntervalSeconds": 5
  },
  "Exchanges": [
    {
      "Exchange": "Binance",
      "Enabled": true,
      "BaseUrl": "https://api.binance.com",
      "StableCoins": [ "USDT", "USDC" ],
      "Coins": [ "BTC", "ETH", "XRP", "LTC", "TON" ]
    },
    {
      "Exchange": "ByBit",
      "Enabled": true,
      "BaseUrl": "https://api.bybit.com",
      "StableCoins": [ "USDT", "USDC" ],
      "Coins": [ "BTC", "ETH", "XRP", "LTC", "TON" ]
    }
  ],
  "Storage": {
    "Db": "prices.duckdb"
  },
  "Kafka": {
    "BootstrapServers": "kafka:9093",
    "Username": "testuser",
    "Password": "testpass"
